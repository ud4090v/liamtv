[Unit]
Description=LiamTV Stream API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/codex-sessions/liamtv-roku/stream-api
Environment=LIAMTV_API_KEY=liam2026
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
