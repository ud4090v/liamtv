{
  "rewrites": [
    { "source": "/", "destination": "/tv-player.html" },
    { "source": "/manage", "destination": "/manage.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
